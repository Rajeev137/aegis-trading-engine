# Copy this file to .env and fill in the values:  cp .env.example .env
#
# The hostnames below (postgres / redis / rabbitmq) are the docker-compose
# service names, so these defaults work as-is with `docker compose up`.
# If you run the services directly on your machine instead, swap them for localhost.

# Async Postgres connection (note the +asyncpg driver)
DATABASE_URL=postgresql+asyncpg://aegis_admin:supersecretpassword@postgres:5432/aegis_db

# Signs JWT auth tokens. Generate a strong one for anything non-local:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change_me_to_a_long_random_string

# Redis cache (live price + rate-limit counters)
REDIS_URL=redis://redis:6379/0

# RabbitMQ message bus
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
